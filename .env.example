# ============================================================================
# ENVIRONMENT VARIABLES - Trading Bot (EXAMPLE)
# ============================================================================
# Copia este archivo a .env y rellena con tus valores reales
# NUNCA subas el archivo .env a git (ya está en .gitignore)
# ============================================================================

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=trading_bot

# Redis Configuration
REDIS_URL=redis://redis:6379

# Security (¡CAMBIAR TODAS EN PRODUCCIÓN!)
# Generar JWT_SECRET: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Generar ENCRYPTION_MASTER_KEY: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your-encryption-master-key-32-chars-min
# Generar API_SECRET_KEY: openssl rand -hex 32
API_SECRET_KEY=your-api-secret-key-for-sensitive-operations-64chars

# External APIs
# Obtener API key en: https://twelvedata.com/
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
TWELVE_DATA_CACHE_TTL=300

# Email Configuration (Opcional - usar Resend)
RESEND_API_KEY=your_resend_api_key_here

# WhatsApp via TextMeBot (Opcional, 3 días gratis)
# https://textmebot.com/
WHATSAPP_PHONE=+1234567890
WHATSAPP_APIKEY=your_textmebot_apikey
WHATSAPP_ENABLED=false

# Telegram Bot (GRATIS permanente)
# Crear bot con @BotFather, obtener chat ID con @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=true
TELEGRAM_ONLY_FIRE=false
FRONTEND_URL=http://localhost:3000

# Email Configuration
SENDER_EMAIL=noreply@tradingbot.com
REPORT_EMAIL=your-email@example.com

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS Origins (separados por coma, sin espacios)
# En producción: solo tu dominio
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=300
ACCOUNT_LOCKOUT_DURATION=900

# ML y Plan Twelve Data
TWELVE_DATA_DAILY_LIMIT=5000
ACCOUNT_MODE=demo

# Pocket Option Session (Opcional - para WebSocket)
# Extraer de cookie ci_session en navegador
PO_SSID=your_po_session_id_here
PO_FULL_COOKIE=your_po_full_cookie_here
