# ============================================================================
# PRODUCCIÓN - Variables de Entorno
# ============================================================================
# Copiar a .env.production y rellenar con valores REALES
# NUNCA subir .env.production a git
# ============================================================================

# MongoDB Configuration
MONGO_URL=mongodb://mongo:27017
DB_NAME=trading_bot

# Redis Configuration
REDIS_URL=redis://redis:6379

# =============================================================================
# SEGURIDAD - ¡CAMBIAR TODOS EN PRODUCCIÓN!
# Generar con: openssl rand -hex 32
# =============================================================================
JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria_64_caracteres
ENCRYPTION_MASTER_KEY=otra_clave_larga_y_aleatoria_de_64_caracteres_aqui
API_SECRET_KEY=clave_api_para_proteger_endpoints_post_64caracteres

# =============================================================================
# EXTERNAL APIs
# =============================================================================
# Twelve Data: https://twelvedata.com/
TWELVE_DATA_API_KEY=tu_api_key_de_twelve_data
TWELVE_DATA_CACHE_TTL=300
TWELVE_DATA_DAILY_LIMIT=5000

# Resend (Email): https://resend.com/
RESEND_API_KEY=tu_api_key_de_resend

# =============================================================================
# TELEGRAM BOT
# Obtener de @BotFather y @userinfobot
# =============================================================================
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
TELEGRAM_ENABLED=true
TELEGRAM_ONLY_FIRE=false

# =============================================================================
# POCKET OPTION (WebSocket - Opcional)
# Extraer de cookie ci_session del navegador
# PO_USER_ID + PO_SECRET: necesarios para 42["auth",...] y feed de precios (ver Network en PO)
# =============================================================================
PO_SSID=tu_session_id_aqui
PO_FULL_COOKIE=tu_cookie_completo_aqui
PO_USER_ID=0
PO_SECRET=

# =============================================================================
# CONFIGURACIÓN
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=WARNING
FRONTEND_URL=https://tudominio.com

# CORS - Solo tu dominio de producción (separado por comas)
CORS_ORIGINS=https://tudominio.com

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=300
ACCOUNT_LOCKOUT_DURATION=900

# Application
ACCOUNT_MODE=demo

# Auto-ejecución — copiar también a .env.production en el VPS (no versionar ese archivo)
# DEMO: acumula estadística sin dinero real; place_trade usa siempre isDemo=1
AUTO_EXECUTE=true
AUTO_EXECUTE_MODE=demo
AUTO_EXECUTE_MIN_WR=55
AUTO_EXECUTE_MIN_OPS=20
AUTO_EXECUTE_AMOUNT=100

# =============================================================================
# NOTIFICACIONES
# =============================================================================
SENDER_EMAIL=noreply@tudominio.com
REPORT_EMAIL=tu-email@example.com

# WhatsApp (TextMeBot - Opcional)
WHATSAPP_PHONE=+1234567890
WHATSAPP_APIKEY=tu_apikey_textmebot
WHATSAPP_ENABLED=false
